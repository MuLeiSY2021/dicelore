{
  "mcpServers": {
    "dicelore-play": {
      "command": "npx",
      "args": ["tsx", "harness/eval-dicegm/play-mcp.ts"],
      "env": {
        "DICELORE_PLAY_URL": "http://localhost:8787",
        "DICELORE_SESSIONS_DIR": ".dl-eval-doctrine"
      }
    },
    "dicelore-build": {
      "command": "npx",
      "args": ["tsx", "harness/eval-loregm/build-mcp.ts"],
      "env": {
        "DICELORE_PLAY_URL": "http://localhost:8787"
      }
    }
  }
}
